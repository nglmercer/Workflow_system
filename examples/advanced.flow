// Advanced .flow example with loops and complex logic

// One `@import` per event. Each one declares a synthetic binding
// whose shape comes from the JSON file next to this one: the keys
// become fields of the binding, the value types drive hover and
// member completion. The binding name doesn't have to be the event
// name, but matching them keeps things readable — and the
// `unused-workflow` lint recognises an imported event as
// "external" (alongside the SCREAMING_SNAKE_CASE convention).
@import USER_REGISTERED from "./user_registered.json"
@import BATCH_START from "./batch_start.json"
@import COMPLEX_EVENT from "./complex_event.json"
@import NESTED_DATA from "./nested_data.json"

// Utility functions
//@string,@string
fn formatCurrency(amount, currency) {
  return currency + " " + amount
}
//@string
fn validateEmail(email) {
  var length = email.length
  if (length > 5) {
    return true
  }
  return false
}

// Workflows
workflow "User Registration" {
  on USER_REGISTERED

  if (validateEmail(USER_REGISTERED.email)) {
    log("Valid email: " + USER_REGISTERED.email)
  } else {
    log("Invalid email: " + USER_REGISTERED.email)
  }

  if (USER_REGISTERED.plan == "premium") {
    log("Premium user registration")
  }
}

workflow "Batch Processing" {
  on BATCH_START

  foreach (item in BATCH_START.items) {
    log("Processing batch item: " + item.id)
    if (item.priority == "high") {
      log("High priority item")
    }
  }
}

workflow "Complex Conditions" {
  on COMPLEX_EVENT

  if (COMPLEX_EVENT.value > 100 && COMPLEX_EVENT.type == "important") {
    log("Important high value event")
  } else if (COMPLEX_EVENT.value > 50 || COMPLEX_EVENT.urgent == true) {
    log("Medium priority event")
  } else {
    log("Low priority event")
  }
}

// `NESTED_DATA` is treated as external because we imported a
// schema with that name above. The destructure params `users` and
// `meta` are typed from the schema's fields, so `users.length` and
// `user.name` are all resolved statically.
workflow "Nested Loops" {
  on NESTED_DATA ({users, meta})
  log("Users: " + users.length + ", Meta: " + meta.length)
  foreach (user in users) {
    log("User: " + user.name)
    foreach (order in user.orders) {
      log("  Order: " + order.id)
      if (order.total > 100) {
        log("    High value order")
      }
    }
  }
}

workflow "Math Operations" {
  on CALCULATE

  var x = 10
  var y = 20
  var result = x + y * 2

  if (result > 50) {
    log("Result is large: " + result)
  } else {
    log("Result is small: " + result)
  }
}
